+/* OBB linear gradient coordinates: SVG spec says plain numbers like x1="0" y1="0" x2="0" y2="1"
+ * are fractions in [0,1] of the bounding box. nsvg__convertToPixels() for NSVG_UNITS_USER
+ * ignores orig/length and returns the raw value, so we need a separate converter for OBB mode. */
+static float nsvg__convertToPixelsOBB(NSVGcoordinate c, float orig, float length)
+{
+	if (c.units == NSVG_UNITS_PERCENT)
+		return orig + c.value / 100.0f * length;
+	return orig + c.value * length;
+}
